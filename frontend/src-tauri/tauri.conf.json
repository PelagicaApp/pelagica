{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Pelagica",
    "version": "0.1.0",
    "identifier": "app.pelagica.desktop",
    "build": {
        "frontendDist": "../dist",
        "devUrl": "http://localhost:3000"
    },
    "app": {
        "windows": [
            {
                "title": "Pelagica",
                "width": 1600,
                "height": 1000,
                "resizable": true,
                "fullscreen": false,
                "transparent": true
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "resources": ["lib/**/*"],
        "android": {
            "debugApplicationIdSuffix": ".debug"
        }
    }
}
